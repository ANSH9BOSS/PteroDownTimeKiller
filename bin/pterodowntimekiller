#!/usr/bin/env node

const axios = require('axios');
const path = require('path');
const fs = require('fs-extra');
const { getConfig } = require('../src/config');
const { createSnapshot, listSnapshots } = require('../src/snapshotEngine');
const { performGDriveBackup } = require('../src/gdrive');
const { handleWebhookCommand } = require('../src/webhookCommands');

const args = process.argv.slice(2);
const command = args[0];
const subCommand = args[1];

async function main() {
  const cfg = getConfig();

  switch (command) {
    case 'status': {
      console.log('\n=====================================================');
      console.log('⚡ PteroDownTimeKiller - Cluster Status');
      console.log('=====================================================');
      console.log(`Local Node ID : ${cfg.node?.id || 'panel-a'}`);
      console.log(`Local IP / WG : ${cfg.node?.wireguardIp || '10.0.0.1'}`);
      console.log(`Peer Address  : ${cfg.peer?.host || '10.0.0.2'}:${cfg.peer?.port || 4000}`);
      console.log(`Daemon Port   : ${cfg.node?.port || 4000}`);
      console.log('=====================================================\n');

      try {
        const res = await axios.get(`http://127.0.0.1:${cfg.node?.port || 4000}/api/sync/status`);
        console.log('Daemon Status : ONLINE (200 OK)');
        console.log(`Peer Status   : ${res.data.peerConnected ? 'CONNECTED' : 'OFFLINE'}`);
        if (res.data.latencyMs) console.log(`Peer Latency  : ${res.data.latencyMs} ms`);
      } catch (err) {
        console.log('Daemon Status : OFFLINE / UNREACHABLE');
      }
      break;
    }

    case 'snapshot': {
      if (subCommand === 'create') {
        console.log('Creating database snapshot...');
        const res = await createSnapshot('cli_user');
        if (res.success) {
          console.log(`✅ Snapshot created: ${res.snapshotName} (${res.fileSize})`);
        } else {
          console.error(`❌ Snapshot failed: ${res.error}`);
        }
      } else if (subCommand === 'list') {
        const snapshots = await listSnapshots();
        console.log('\n--- Local & GDrive Snapshots ---');
        snapshots.forEach((s) => console.log(`• ${s.name} (${s.size})`));
      } else {
        console.log('Usage: pterodowntimekiller snapshot [create|list]');
      }
      break;
    }

    case 'gdrive':
    case 'backup': {
      console.log('Initiating Google Drive backup...');
      const res = await performGDriveBackup();
      if (res.success) {
        console.log(`✅ Google Drive Backup Complete: ${res.archiveName} (${res.fileSize})`);
      } else {
        console.error(`❌ Backup failed: ${res.error}`);
      }
      break;
    }

    case 'sync-now': {
      console.log('Triggering manual re-sync cycle...');
      await handleWebhookCommand('sync-now');
      console.log('✅ Re-sync triggered.');
      break;
    }

    case 'webhook': {
      if (!subCommand) {
        const readline = require('readline').createInterface({
          input: process.stdin,
          output: process.stdout
        });
        readline.question('🔗 Enter your Discord Webhook URL: ', async (url) => {
          readline.close();
          const cleanUrl = url.trim();
          if (!cleanUrl.startsWith('https://discord.com/api/webhooks/')) {
            console.error('❌ Invalid Discord Webhook URL format. URL must start with: https://discord.com/api/webhooks/');
            process.exit(1);
          }
          
          // Save to config file
          const configPath = '/etc/pterodowntimekiller/config.json';
          try {
            if (fs.existsSync(configPath)) {
              const currentConfig = fs.readJsonSync(configPath);
              currentConfig.discord = currentConfig.discord || {};
              currentConfig.discord.webhookUrl = cleanUrl;
              currentConfig.discord.enabled = true;
              fs.writeJsonSync(configPath, currentConfig, { spaces: 2 });
              console.log('✅ Discord Webhook URL saved successfully to /etc/pterodowntimekiller/config.json!');
              
              // Reload daemon if running
              const { exec } = require('child_process');
              exec('systemctl restart pterodowntimekiller', (err) => {
                if (!err) console.log('🔄 Sync daemon restarted automatically.');
              });
            } else {
              console.error('❌ Config file /etc/pterodowntimekiller/config.json not found. Run install.sh first.');
            }
          } catch (err) {
            console.error(`❌ Failed to write config: ${err.message}`);
          }
        });
        break;
      }

      if (subCommand === 'test') {
        console.log('Sending test Discord Webhook notification...');
        await handleWebhookCommand('status');
        console.log('✅ Test webhook sent.');
      } else if (subCommand === 'send') {
        const msg = args.slice(2).join(' ');
        if (!msg) {
          console.error('Please specify message text: pterodowntimekiller webhook send "your message"');
          break;
        }
        const { sendDiscordWebhook } = require('../src/webhooks');
        await sendDiscordWebhook('📢 ADMIN MESSAGE', msg, 0x3b82f6);
        console.log('✅ Message dispatched to Discord Webhook.');
      } else {
        console.log('Usage: pterodowntimekiller webhook [test|send "message"]');
      }
      break;
    }

    case 'verify': {
      console.log('\n=====================================================');
      console.log('⚡ PteroDownTimeKiller - Cluster Verification Check');
      console.log('=====================================================');
      try {
        const res = await axios.get(`http://127.0.0.1:${cfg.node?.port || 4000}/api/sync/verify-cluster?secret=${cfg.secret}`);
        console.log(`Local Panel URL  : ${res.data.localAppUrl}`);
        console.log(`Peer Panel URL   : ${res.data.peerAppUrl}`);
        console.log(`URL Configurations Match: ${res.data.urlsMatch ? '✅ MATCHING (Perfect active-active setup!)' : '❌ MISMATCH (Action Required: Ensure APP_URL matches on both panels!)'}`);
        console.log('\n--- Wings Nodes Connection Check ---');
        if (res.data.nodes && res.data.nodes.length > 0) {
          res.data.nodes.forEach(n => {
            console.log(`• Node [${n.id}] ${n.name} (${n.fqdn}:${n.port}) -> ${n.isHealthy ? '🟢 Connected & Online' : '🔴 Connection Failed / Offline'}`);
          });
        } else {
          console.log('No Wings nodes configured in this Pterodactyl cluster yet.');
        }
      } catch (err) {
        console.error(`❌ Failed to run verification diagnostics: ${err.message}`);
      }
      console.log('=====================================================\n');
      break;
    }

    case 'peer': {
      const peerHost = subCommand;
      const peerPort = args[2] ? parseInt(args[2], 10) : 80;
      if (!peerHost) {
        console.error('Usage: pterodowntimekiller peer <ip/domain> [port]');
        break;
      }
      const configPath = '/etc/pterodowntimekiller/config.json';
      try {
        if (fs.existsSync(configPath)) {
          const currentConfig = fs.readJsonSync(configPath);
          currentConfig.peer = currentConfig.peer || {};
          currentConfig.peer.host = peerHost;
          currentConfig.peer.port = peerPort;
          fs.writeJsonSync(configPath, currentConfig, { spaces: 2 });
          console.log(`✅ Configured peer connection to: ${peerHost}:${peerPort}`);
          const { exec } = require('child_process');
          exec('systemctl restart pterodowntimekiller', (err) => {
            if (!err) console.log('🔄 Sync daemon restarted automatically.');
          });
        } else {
          console.error('❌ Configuration file not found.');
        }
      } catch (err) {
        console.error(`❌ Failed to update config: ${err.message}`);
      }
      break;
    }

    case 'config': {
      console.log('\n--- PteroDownTimeKiller Configuration ---');
      const cleanConfig = { ...cfg };
      if (cleanConfig.database) cleanConfig.database.pass = '********';
      if (cleanConfig.secret) cleanConfig.secret = '********';
      if (cleanConfig.discord && cleanConfig.discord.webhookUrl) {
        cleanConfig.discord.webhookUrl = cleanConfig.discord.webhookUrl.substring(0, 45) + '...';
      }
      console.log(JSON.stringify(cleanConfig, null, 2));
      break;
    }

    case 'restart': {
      const { execSync } = require('child_process');
      try {
        execSync('systemctl restart pterodowntimekiller');
        console.log('✅ PteroDownTimeKiller daemon restarted successfully.');
      } catch (err) {
        console.error(`❌ Failed to restart daemon: ${err.message}`);
      }
      break;
    }

    case 'logs': {
      const { exec } = require('child_process');
      exec('tail -n 50 /var/log/pterodowntimekiller/daemon.log 2>/dev/null || tail -n 50 logs/daemon.log', (err, stdout) => {
        if (!err) console.log(stdout);
      });
      break;
    }

    default: {
      console.log(`
⚡ PteroDownTimeKiller CLI Management Tool

Usage:
  pterodowntimekiller status                 Show live cluster status & peer connection
  pterodowntimekiller verify                 Run cluster domain & Wings verification check
  pterodowntimekiller webhook                Setup your Discord Webhook URL interactively
  pterodowntimekiller webhook test           Send a test notification to Discord Webhook
  pterodowntimekiller webhook send "msg"     Dispatch a custom message to Discord Webhook
  pterodowntimekiller snapshot create        Create an immediate DB & Node snapshot
  pterodowntimekiller snapshot list          List all local and Google Drive snapshots
  pterodowntimekiller gdrive backup          Trigger full offsite backup to Google Drive
  pterodowntimekiller sync-now               Trigger manual synchronization
  pterodowntimekiller peer <ip/domain> [port] Configure target peer connection (default port: 80)
  pterodowntimekiller config                 View current daemon configuration
  pterodowntimekiller restart                Restart the active-active sync daemon
  pterodowntimekiller logs                   View recent sync event daemon logs
      `);
    }
  }
}

main().catch(console.error);
